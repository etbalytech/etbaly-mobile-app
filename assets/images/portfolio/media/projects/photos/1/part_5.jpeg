  <body>
    <!-- H1 مخفي للـ SEO بس مش هيأثر على الشكل -->
    <h1 style="position: absolute; width: 1px; height: 1px; overflow: hidden; opacity: 0">
      اطبعلي للدعاية والإعلان - تسويق رقمي وتصميم مواقع في الاسكندرية
    </h1>

    <div id="lux-splash">
      <!-- Grid lines (decorative) -->
      <svg class="splash-grid" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- vertical lines -->
        <line x1="20%" y1="0" x2="20%" y2="100%"/>
        <line x1="50%" y1="0" x2="50%" y2="100%"/>
        <line x1="80%" y1="0" x2="80%" y2="100%"/>
        <!-- horizontal lines -->
        <line x1="0" y1="25%" x2="100%" y2="25%"/>
        <line x1="0" y1="75%" x2="100%" y2="75%"/>
      </svg>

      <!-- Corner ornaments -->
      <div class="corner corner-tl">
        <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <polyline points="0,20 0,0 20,0" class="corner-stroke"/>
          <circle cx="0" cy="0" r="2.5" fill="#d4af37" class="corner-dot"/>
        </svg>
      </div>
      <div class="corner corner-tr">
        <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <polyline points="0,20 0,0 20,0" class="corner-stroke"/>
          <circle cx="0" cy="0" r="2.5" fill="#d4af37" class="corner-dot"/>
        </svg>
      </div>
      <div class="corner corner-bl">
        <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <polyline points="0,20 0,0 20,0" class="corner-stroke"/>
          <circle cx="0" cy="0" r="2.5" fill="#d4af37" class="corner-dot"/>
        </svg>
      </div>
      <div class="corner corner-br">
        <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <polyline points="0,20 0,0 20,0" class="corner-stroke"/>
          <circle cx="0" cy="0" r="2.5" fill="#d4af37" class="corner-dot"/>
        </svg>
      </div>

      <!-- Main Loader -->
      <div class="lux-loader">
        <div class="logo-wrap">
          <div class="ring-outer"></div>
          <div class="ring-inner"></div>
          <img src="/logo.png" class="logo-img" alt="Etbaly" onerror="this.style.display = 'none'">
        </div>

        <div class="brand-name" id="brandName">اطْبَعَلِيٌّ</div>

        <div class="divider">
          <div class="divider-line"></div>
          <div class="divider-diamond"></div>
          <div class="divider-line right"></div>
        </div>

        <div class="sub-text" id="subText">جاري التحميل</div>

        <div class="progress-wrap">
          <div class="progress-track">
            <div class="progress-bar"></div>
          </div>
          <div class="progress-dots">
            <div class="dot active"></div>
            <div class="dot active"></div>
            <div class="dot active"></div>
            <div class="dot"></div>
            <div class="dot"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Pages For Angular Router to Render Into -->
    <app-root></app-root>

    <script>
      // ── Apply theme & lang BEFORE first paint ──────────
      (function () {
        const theme = localStorage.getItem('theme') || 'dark';
        const lang = localStorage.getItem('lang') || 'ar';
        const splash = document.getElementById('lux-splash');
        const brandEl = document.getElementById('brandName');
        const subEl = document.getElementById('subText');

        if (theme === 'light') {
          splash.classList.add('light');
        }

        if (lang === 'en') {
          brandEl.textContent = '𝗘𝘁𝗯𝗮𝗹𝘆';
          subEl.textContent = 'Loading';
          document.documentElement.dir = 'ltr';
          document.documentElement.lang = 'en';
        } else {
          document.documentElement.dir = 'rtl';
          document.documentElement.lang = 'ar';
        }
      })();

      // ── Dismiss after app load ─────────────────────────
      window.addEventListener('load', function () {
        var splash = document.getElementById('lux-splash');
        // 600ms instead of 1200ms — app is ready, no need to wait longer
        setTimeout(function () {
          splash.classList.add('fade-out');
          setTimeout(function () {
            splash.style.display = 'none';
          }, 600); // fade transition reduced from 700 → 600ms
        }, 600);
      });
    </script>
    <noscript>Please enable JavaScript to continue using this application.</noscript>
  <link rel="modulepreload" href="chunk-XOGOWMGD.js"><link rel="modulepreload" href="chunk-44JIRCWO.js"><link rel="modulepreload" href="chunk-2ZHU5P6F.js"><link rel="modulepreload" href="chunk-P3HVX5GL.js"><link rel="modulepreload" href="chunk-KAT7YFEL.js"><script src="main-RQQDSOEY.js" type="module"></script></body>
</html>
